{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "opendev",
  "description": "Visual transaction profiler and debugger for Solana",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "guides/installation",
              "guides/quickstart"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "guides/cli-commands",
              "guides/cli-flags",
              "guides/source-file-runners",
              "guides/configuration"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "guides/ai-insights"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Documentation",
            "pages": [
              "reference/architecture",
              "reference/project-structure",
              "reference/troubleshooting"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/OpenSubmissionn/Open_DevTool",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/OpenSubmissionn/Open_DevTool"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/OpenSubmissionn/Open_DevTool"
    }
  }
}
