{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "opendev",
  "description": "Visual transaction profiler and debugger for Solana",
  "colors": {
    "primary": "#4B6CB3",
    "light": "#93B5E1",
    "dark": "#1E3A8A"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0D1530"
    },
    "decoration": "gradient"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "guides/installation",
              "guides/quickstart"
            ]
          },
          {
            "group": "Usage",
            "pages": [
              "guides/cli-commands",
              "guides/cli-flags",
              "guides/source-file-runners",
              "guides/configuration"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "guides/ai-insights"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Documentation",
            "pages": [
              "reference/architecture",
              "reference/project-structure"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/OpenSubmissionn/Open_DevTool",
          "icon": "github"
        },
        {
          "anchor": "NPM",
          "href": "https://www.npmjs.com/package/opendevtool",
          "icon": "npm"
        },
        {
          "anchor": "@OpenDevT",
          "href": "https://x.com/OpenDevT",
          "icon": "x-twitter"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/OpenSubmissionn/Open_DevTool"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Web Version",
      "href": "https://opendev-tx-solana.vercel.app/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/OpenSubmissionn/Open_DevTool",
      "x": "https://x.com/OpenDevT"
    }
  }
}
